# =============================================================================
# HERMES AGENT — Configuração de Ambiente
# Copie este arquivo para .env e preencha suas chaves
# NUNCA suba o .env para o GitHub! (já está no .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# 🔑 CHAVES DE API (pelo menos uma é obrigatória)
# -----------------------------------------------------------------------------

# Nous Portal (recomendado — modelos Hermes nativos)
# NOUS_API_KEY=sua_chave_aqui

# OpenRouter (200+ modelos disponíveis)
# OPENROUTER_API_KEY=sua_chave_aqui

# OpenAI
# OPENAI_API_KEY=sua_chave_aqui

# Groq (rápido e gratuito para alguns modelos)
# GROQ_API_KEY=sua_chave_aqui

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sua_chave_aqui

# Kimi / Moonshot
# MOONSHOT_API_KEY=sua_chave_aqui

# -----------------------------------------------------------------------------
# 🤖 MODELO PADRÃO
# Formato: provider:modelo
# Exemplos:
#   openrouter:mistralai/mistral-7b-instruct
#   openrouter:nousresearch/hermes-3-llama-3.1-405b
#   groq:llama-3.3-70b-versatile
#   openai:gpt-4o-mini
# -----------------------------------------------------------------------------
HERMES_MODEL=openrouter:nousresearch/hermes-3-llama-3.1-405b

# -----------------------------------------------------------------------------
# 📱 GATEWAY DE MENSAGENS (Telegram, Discord, WhatsApp, etc.)
# -----------------------------------------------------------------------------

# Telegram Bot Token (obtenha via @BotFather)
# TELEGRAM_TOKEN=sua_chave_aqui

# Discord Bot Token
# DISCORD_TOKEN=sua_chave_aqui

# WhatsApp (via Twilio)
# TWILIO_ACCOUNT_SID=sua_chave_aqui
# TWILIO_AUTH_TOKEN=sua_chave_aqui
# TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# ⚙️ CONFIGURAÇÕES DO TERMINAL (ambiente de execução de código)
# -----------------------------------------------------------------------------
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300

# -----------------------------------------------------------------------------
# 🌐 CONFIGURAÇÕES DO BROWSER (Playwright)
# -----------------------------------------------------------------------------
BROWSER_SESSION_TIMEOUT=300
BROWSER_INACTIVITY_TIMEOUT=120
BROWSERBASE_PROXIES=false
BROWSERBASE_ADVANCED_STEALTH=false

# -----------------------------------------------------------------------------
# 🔧 DEBUG (deixe false em produção)
# -----------------------------------------------------------------------------
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
MOA_TOOLS_DEBUG=false
IMAGE_TOOLS_DEBUG=false
